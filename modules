      {zh:"说得不好",py:"shuō de bù hǎo",en:"don't speak it well"},
      {zh:"帮我改错",py:"bāng wǒ gǎi cuò",en:"help me correct mistakes"},
      {zh:"南京话",py:"nánjīnghuà",en:"Nanjing dialect"},
      {zh:"口音",py:"kǒuyīn",en:"accent"},
      {zh:"听得懂",py:"tīng de dǒng",en:"can understand"},
      {zh:"慢慢来",py:"màn màn lái",en:"take it slow"},
      {zh:"加油",py:"jiāyóu",en:"keep it up!"}
    ],
    sentences:[
      {en:"My Chinese isn't great, I'm practicing.",zh:"我中文说得不好，在练。",words:["我中文","说得不好","在练","口音","帮我改错"]},
      {en:"My family speaks Nanjing dialect.",zh:"我家说南京话。",words:["我家","说","南京话","普通话","口音","在练"]},
      {en:"Can you help me correct my mistakes?",zh:"你能帮我改错吗？",words:["你能","帮我改错","吗","慢慢来","加油","说得不好"]}
    ]
  }
];

let curTopic = 0;
let curMode = "vocab";
let quizOrder = [], quizIdx = 0, quizScore = 0, quizAnswered = false;
let buildIdx = 0, builtWords = [], usedIdxs = [];

function init() {
  const list = document.getElementById("topicList");
  topics.forEach((t, i) => {
    const btn = document.createElement("button");
    btn.className = "topic-btn" + (i===0?" active":"");
    btn.innerHTML = `<span class="topic-num">${String(i+1).padStart(2,"0")}</span>${t.zh}`;
    btn.onclick = () => selectTopic(i);
    list.appendChild(btn);
  });
  renderTopic();
}

function selectTopic(i) {
  curTopic = i;
  document.querySelectorAll(".topic-btn").forEach((b,j) => b.classList.toggle("active", j===i));
  setMode("vocab");
  document.querySelectorAll(".mode-tab").forEach((t,j) => t.classList.toggle("active", j===0));
}

function setMode(m) {
  curMode = m;
  document.querySelectorAll(".mode-tab").forEach((t,i) => {
    t.classList.toggle("active", ["vocab","quiz","build"][i] === m);
  });
  document.getElementById("sec-vocab").classList.toggle("visible", m==="vocab");
  document.getElementById("sec-quiz").classList.toggle("visible", m==="quiz");
  document.getElementById("sec-build").classList.toggle("visible", m==="build");
  if (m==="vocab") renderVocab();
  if (m==="quiz") initQuiz();
  if (m==="build") initBuild();
}

function renderTopic() {
  const t = topics[curTopic];
  document.getElementById("topicZh").textContent = t.zh;
  document.getElementById("topicEn").textContent = t.en;
  renderVocab();
}

function renderVocab() {
  const t = topics[curTopic];
  document.getElementById("sec-vocab").innerHTML =
    `<p class="hint">Tap a card to reveal the meaning. Tap again to flip back.</p>
     <div class="vocab-grid">${t.vocab.map(v=>`
      <div class="vocab-card" onclick="this.classList.toggle('flipped')">
        <div class="zh-big">${v.zh}</div>
        <div class="pinyin">${v.py}</div>
        <div class="en-sm">${v.en}</div>
      </div>`).join("")}</div>`;
}

function initQuiz() {
  const t = topics[curTopic];
  quizOrder = [...t.vocab].sort(()=>Math.random()-0.5);
  quizIdx = 0; quizScore = 0; quizAnswered = false;
  renderQuestion();
}

function renderQuestion() {
  const t = topics[curTopic];
  const sec = document.getElementById("sec-quiz");
  if (quizIdx >= quizOrder.length) {
    sec.innerHTML = `
      <div class="done-state">
        <div class="big">完成！</div>
        <p>Score: ${quizScore} / ${quizOrder.length}</p>
        <button class="btn btn-primary" onclick="initQuiz()">Try again</button>
      </div>`;
    return;
  }
  const item = quizOrder[quizIdx];
  const pct = Math.round((quizIdx/quizOrder.length)*100);
  let opts = [item.en];
  const pool = t.vocab.filter(v=>v.en!==item.en).sort(()=>Math.random()-0.5).slice(0,3);
  pool.forEach(p=>opts.push(p.en));
  opts = opts.sort(()=>Math.random()-0.5);

  sec.innerHTML = `
    <div class="progress-bar"><div class="progress-fill" id="pFill" style="width:${pct}%"></div></div>
    <div class="quiz-box">
      <div class="quiz-prompt">${item.zh}</div>
      <div class="quiz-pinyin">${item.py}</div>
      <div class="quiz-options" id="qOpts">
        ${opts.map(o=>`<button class="quiz-opt" onclick="answerQuiz(this,'${o.replace(/'/g,"\\'")}','${item.en.replace(/'/g,"\\'")}')">${o}</button>`).join("")}
      </div>
      <div class="quiz-feedback" id="qFeedback"></div>
    </div>
    <div class="quiz-nav">
      <span class="quiz-score">Score: ${quizScore} / ${quizOrder.length}</span>
      <button class="btn" onclick="nextQuestion()">Next →</button>
    </div>`;
}

function answerQuiz(btn, chosen, correct) {
  if (quizAnswered) return;
  quizAnswered = true;
  const isCorrect = chosen === correct;
  btn.classList.add(isCorrect ? "correct" : "wrong");
  if (!isCorrect) {
    document.querySelectorAll(".quiz-opt").forEach(b => { if (b.textContent === correct) b.classList.add("correct"); });
  }
  if (isCorrect) quizScore++;
  document.getElementById("qFeedback").textContent = isCorrect ? "正确！" : "答案是：" + correct;
  document.querySelector(".quiz-score").textContent = "Score: " + quizScore + " / " + quizOrder.length;
}

function nextQuestion() { quizIdx++; quizAnswered = false; renderQuestion(); }

function initBuild() { buildIdx = 0; renderBuild(); }

function renderBuild() {
  const t = topics[curTopic];
  const sec = document.getElementById("sec-build");
  if (buildIdx >= t.sentences.length) {
    sec.innerHTML = `
      <div class="done-state">
        <div class="big">全部完成！</div>
        <p>All sentences done. Great work.</p>
        <button class="btn btn-primary" onclick="initBuild()">Start over</button>
      </div>`;
    return;
  }
  const s = t.sentences[buildIdx];
  builtWords = []; usedIdxs = [];
  const allWords = [...s.words].sort(()=>Math.random()-0.5);
  sec.innerHTML = `
    <p class="build-prompt">Arrange the words to build the sentence:</p>
    <p class="build-en">"${s.en}"</p>
    <div class="build-display" id="bDisplay"><span style="color:#a8a8a2;font-size:14px;">tap words below to add…</span></div>
    <div class="word-chips" id="bChips">
      ${allWords.map((w,i)=>`<span class="word-chip" data-idx="${i}" onclick="addWord('${w.replace(/'/g,"\\'")}',${i},this)">${w}</span>`).join("")}
    </div>
    <div class="build-result" id="bResult"></div>
    <div class="action-row">
      <button class="btn" onclick="clearBuild()">Clear</button>
      <button class="btn" onclick="checkBuild()">Check ✓</button>
      <button class="btn" onclick="revealBuild()">Show answer</button>
    </div>
    <div class="build-counter">${buildIdx+1} of ${t.sentences.length}</div>`;
}

function addWord(w, idx, chip) {
  if (usedIdxs.includes(idx)) return;
  usedIdxs.push(idx);
  chip.classList.add("used");
  builtWords.push({w, idx});
  refreshDisplay();
}

function refreshDisplay() {
  const d = document.getElementById("bDisplay");
  if (!builtWords.length) { d.innerHTML = `<span style="color:#a8a8a2;font-size:14px;">tap words below to add…</span>`; return; }
  d.innerHTML = builtWords.map((item, pos) =>
    `<span class="built-word" onclick="removeWord(${pos},${item.idx})">${item.w}</span>`).join("");
}

function removeWord(pos, idx) {
  builtWords.splice(pos, 1);
  usedIdxs = usedIdxs.filter(i=>i!==idx);
  document.querySelectorAll(".word-chip").forEach(c => { if (parseInt(c.dataset.idx)===idx) c.classList.remove("used"); });
  refreshDisplay();
  const r = document.getElementById("bResult");
  if (r) { r.textContent=""; r.className="build-result"; }
}

function clearBuild() {
  builtWords=[]; usedIdxs=[];
  document.querySelectorAll(".word-chip").forEach(c=>c.classList.remove("used"));
  refreshDisplay();
  const r = document.getElementById("bResult");
  if (r) { r.textContent=""; r.className="build-result"; }
}

function checkBuild() {
  const t = topics[curTopic];
  const s = t.sentences[buildIdx];
  const built = builtWords.map(b=>b.w).join("");
  const target = s.zh.replace(/[。？！，]/g,"");
  const res = document.getElementById("bResult");
  if (built === target) {
    res.textContent = "正确！ " + s.zh;
    res.className = "build-result ok";
    setTimeout(()=>{ buildIdx++; renderBuild(); }, 1400);
  } else {
    res.textContent = "Not quite — try rearranging!";
    res.className = "build-result bad";
  }
}

function revealBuild() {
  const s = topics[curTopic].sentences[buildIdx];
  const res = document.getElementById("bResult");
  res.textContent = "Answer: " + s.zh;
  res.className = "build-result";
  setTimeout(()=>{ buildIdx++; renderBuild(); }, 2000);
}

init();
</script>
</body>
</html>
