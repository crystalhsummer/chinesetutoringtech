<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chinese Practice — NYC Tech</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #fafaf8;
    --surface: #ffffff;
    --border: rgba(0,0,0,0.09);
    --border-mid: rgba(0,0,0,0.16);
    --text: #1a1a18;
    --text-muted: #6b6b66;
    --text-faint: #a8a8a2;
    --purple-bg: #EEEDFE;
    --purple-text: #3C3489;
    --purple-border: #AFA9EC;
    --purple-mid: #7F77DD;
    --teal-bg: #E1F5EE;
    --teal-text: #085041;
    --teal-border: #5DCAA5;
    --coral-bg: #FAECE7;
    --coral-text: #712B13;
    --coral-border: #F0997B;
    --blue-bg: #E6F1FB;
    --blue-text: #0C447C;
    --blue-border: #85B7EB;
    --amber-bg: #FAEEDA;
    --amber-text: #633806;
    --amber-border: #EF9F27;
    --green-bg: #E1F5EE;
    --green-text: #085041;
    --green-border: #5DCAA5;
    --red-bg: #FCEBEB;
    --red-text: #791F1F;
    --red-border: #F09595;
    --radius: 10px;
    --radius-sm: 6px;
    --radius-pill: 99px;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    font-size: 15px;
    line-height: 1.5;
  }

  /* Header */
  .site-header {
    padding: 1.5rem 1.5rem 0;
    max-width: 820px;
    margin: 0 auto;
  }
  .site-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .site-desc {
    font-size: 13px;
    color: var(--text-faint);
  }

  /* Layout */
  .layout {
    max-width: 820px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  /* Sidebar nav */
  .sidebar {
    position: sticky;
    top: 1.25rem;
  }
  .sidebar-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 8px;
    padding-left: 2px;
  }
  .topic-list { display: flex; flex-direction: column; gap: 2px; }
  .topic-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 7px 10px;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-muted);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    transition: background 0.1s, color 0.1s;
  }
  .topic-btn:hover { background: var(--border); color: var(--text); }
  .topic-btn.active { background: var(--purple-bg); color: var(--purple-text); font-weight: 500; }
  .topic-num {
    font-size: 10px;
    color: var(--text-faint);
    min-width: 16px;
    font-variant-numeric: tabular-nums;
  }
  .topic-btn.active .topic-num { color: var(--purple-mid); }

  /* Main panel */
  .main { min-width: 0; }
  .topic-header { margin-bottom: 1.25rem; }
  .topic-zh { font-size: 22px; font-weight: 600; color: var(--text); line-height: 1.2; }
  .topic-en { font-size: 14px; color: var(--text-muted); margin-top: 3px; }

  /* Mode tabs */
  .mode-tabs {
    display: flex;
    gap: 0;
    border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-sm);
    overflow: hidden;
    width: fit-content;
    margin-bottom: 1.25rem;
  }
  .mode-tab {
    padding: 7px 16px;
    font-size: 13px;
    font-weight: 400;
    background: var(--surface);
    color: var(--text-muted);
    border: none;
    border-right: 0.5px solid var(--border-mid);
    cursor: pointer;
    transition: background 0.1s;
  }
  .mode-tab:last-child { border-right: none; }
  .mode-tab.active { background: var(--bg); color: var(--text); font-weight: 500; }
  .mode-tab:hover:not(.active) { background: var(--bg); }

  /* Sections */
  .section { display: none; }
  .section.visible { display: block; }

  /* Flashcards */
  .hint { font-size: 12px; color: var(--text-faint); margin-bottom: 1rem; }
  .vocab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
  .vocab-card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 12px;
    cursor: pointer;
    text-align: center;
    min-height: 96px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    transition: border-color 0.12s;
    user-select: none;
  }
  .vocab-card:hover { border-color: var(--border-mid); }
  .vocab-card .zh-big { font-size: 20px; color: var(--text); }
  .vocab-card .pinyin { font-size: 11px; color: var(--purple-mid); }
  .vocab-card .en-sm { font-size: 12px; color: var(--text-muted); display: none; }
  .vocab-card.flipped .pinyin { display: none; }
  .vocab-card.flipped .en-sm { display: block; }

  /* Quiz */
  .progress-bar { height: 3px; background: var(--border); border-radius: 99px; margin-bottom: 1.25rem; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--purple-mid); border-radius: 99px; transition: width 0.3s; }
  .quiz-box {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    margin-bottom: 1rem;
  }
  .quiz-prompt { font-size: 28px; font-weight: 500; color: var(--text); text-align: center; margin-bottom: 6px; }
  .quiz-pinyin { font-size: 14px; color: var(--purple-mid); text-align: center; margin-bottom: 1.5rem; }
  .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .quiz-opt {
    padding: 11px 14px;
    border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    transition: background 0.1s;
    font-family: inherit;
  }
  .quiz-opt:hover { background: var(--bg); }
  .quiz-opt.correct { background: var(--teal-bg); border-color: var(--teal-border); color: var(--teal-text); }
  .quiz-opt.wrong { background: var(--red-bg); border-color: var(--red-border); color: var(--red-text); }
  .quiz-feedback { font-size: 13px; color: var(--text-muted); text-align: center; min-height: 20px; margin-top: 12px; }
  .quiz-nav { display: flex; align-items: center; justify-content: space-between; }
  .quiz-score { font-size: 13px; color: var(--text-muted); }

  /* Build sentences */
  .build-prompt { font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .build-en { font-size: 16px; font-weight: 500; color: var(--text); margin-bottom: 12px; }
  .build-display {
    min-height: 54px;
    border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    font-size: 18px;
    color: var(--text);
    margin-bottom: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    background: var(--surface);
  }
  .built-word {
    background: var(--purple-bg);
    color: var(--purple-text);
    border: 0.5px solid var(--purple-border);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    font-size: 15px;
    cursor: pointer;
    user-select: none;
  }
  .word-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .word-chip {
    background: var(--surface);
    color: var(--text);
    border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-sm);
    padding: 7px 13px;
    font-size: 15px;
    cursor: pointer;
    user-select: none;
    transition: background 0.1s;
  }
  .word-chip:hover { background: var(--bg); }
  .word-chip.used { opacity: 0.28; pointer-events: none; }
  .build-result { font-size: 13px; min-height: 20px; margin-top: 4px; }
  .build-result.ok { color: var(--teal-text); }
  .build-result.bad { color: var(--red-text); }
  .build-counter { font-size: 12px; color: var(--text-faint); margin-top: 10px; }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 14px;
    border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.1s;
  }
  .btn:hover { background: var(--bg); }
  .btn-primary {
    background: var(--purple-bg);
    color: var(--purple-text);
    border-color: var(--purple-border);
    font-weight: 500;
  }
  .btn-primary:hover { background: #e0defd; }
  .action-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }

  /* Done state */
  .done-state { text-align: center; padding: 2rem 1rem; }
  .done-state .big { font-size: 32px; margin-bottom: 8px; }
  .done-state p { color: var(--text-muted); font-size: 14px; margin-bottom: 1.25rem; }

  /* Mobile */
  @media (max-width: 600px) {
    .layout { grid-template-columns: 1fr; padding: 1rem; }
    .sidebar { position: static; }
    .topic-list { flex-direction: row; flex-wrap: wrap; gap: 6px; }
    .topic-btn { width: auto; font-size: 12px; padding: 5px 10px; }
    .topic-num { display: none; }
    .quiz-options { grid-template-columns: 1fr; }
  }
</style>
</head>
